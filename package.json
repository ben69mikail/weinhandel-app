{
  "name": "weinhandel-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/backend\" \"npm run dev --workspace=packages/frontend\"",
    "build": "npm run build --workspace=packages/backend && npm run build --workspace=packages/frontend",
    "migrate": "npm run migrate --workspace=packages/backend",
    "migrate:dev": "npm run migrate:dev --workspace=packages/backend",
    "seed": "npm run seed --workspace=packages/backend",
    "studio": "npm run studio --workspace=packages/backend"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  }
}
